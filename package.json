{
    "name": "zodify-env",
    "version": "1.0.1",
    "description": "Automatically generate Zod schemas from your .env files",
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "zodify-env": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --clean",
        "dev": "tsup src/index.ts --format esm --watch",
        "start": "node dist/index.js"
    },
    "homepage": "https://github.com/davidfrid02/zodify-env#readme",
    "repository": {
      "type": "git",
      "url": "https://github.com/davidfrid02/zodify-env.git"
    },
    "keywords": [
        "zod",
        "env",
        "cli",
        "typescript",
        "generator"
    ],
    "author": "David Fried",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.19.33",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}
